# Copy to .env and fill in. Never commit the real .env file.

# platform.openai.com -> API keys
OPENAI_API_KEY=

# Your Auth0 tenant: Applications > APIs, or Application settings > Domain
# Issuer URI is typically https://YOUR_TENANT.us.auth0.com/
AUTH0_ISSUER_URI=
AUTH0_AUDIENCE=

# Local ports are intentionally offset from common defaults used by neighboring projects.
SERVER_PORT=8090
DB_HOST_PORT=55432

# Must match docker-compose.yml's POSTGRES_PASSWORD
DB_PASSWORD=kemet_local_dev
