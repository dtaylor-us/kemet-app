# Copy this file to .env (in the same mobile/ directory) and fill in the value below.
# Never commit .env — it contains your personal network settings.

# Set this to your Mac's current LAN IP and the backend port.
#
# Why LAN IP, not "localhost":
#   When testing on a physical phone, the phone and your Mac are separate devices on
#   the same Wi-Fi. The phone has no way to resolve "localhost" as your Mac — it
#   needs the actual LAN IP address.
#
# How to find your Mac's LAN IP:
#   ipconfig getifaddr en0
#
# Port default:
#   The backend listens on 8090 by default (server.port in application.yml).
#   Match whatever SERVER_PORT you set in backend/.env.
#
# Example:
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.x:8090
